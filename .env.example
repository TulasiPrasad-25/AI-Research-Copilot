# App
APP_NAME=ai-research-copilot
DEBUG=True
SECRET_KEY=your-super-secret-key-change-in-production

# Database
# Local and Streamlit Cloud default:
DATABASE_URL=sqlite:///./research_copilot.db

# PostgreSQL, for Docker Compose or production:
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=research_copilot
POSTGRES_HOST=db
POSTGRES_PORT=5432
# DATABASE_URL=postgresql://postgres:postgres@db:5432/research_copilot

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
USE_CELERY=False

# JWT
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# OpenAI
OPENAI_API_KEY=your-openai-api-key

# FAISS
FAISS_INDEX_PATH=./faiss_index
